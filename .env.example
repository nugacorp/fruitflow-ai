# ---------- Entorno ----------
ENV=development
LOG_LEVEL=INFO
TZ=America/Tijuana
DOMAIN=localhost
ACME_EMAIL=tu@correo.com

# ---------- PostgreSQL ----------
POSTGRES_DB=fruitflow
POSTGRES_USER=fruitflow
POSTGRES_PASSWORD=cambiame
DATABASE_URL=postgresql+asyncpg://fruitflow:cambiame@postgres:5432/fruitflow

# ---------- Redis ----------
REDIS_PASSWORD=cambiame
REDIS_URL=redis://:cambiame@redis:6379/0

# ---------- MinIO ----------
MINIO_USER=fruitflow
MINIO_PASSWORD=cambiame123
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=fruitflow-docs
MINIO_SECURE=false

# ---------- Telegram ----------
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_ALLOWED_USER_IDS=123456789
TELEGRAM_USE_WEBHOOK=false

# ---------- IA ----------
OPENAI_API_KEY=
OPENAI_MODEL_EXTRACCION=gpt-4.1
OPENAI_MODEL_VISION=gpt-4.1
WHISPER_MODEL=whisper-1
AI_DAILY_BUDGET_MXN=200
AI_ENABLED=true

# ---------- Interno ----------
INTERNAL_API_KEY=cambiame
API_BASE_URL=http://backend:8000
EMPRESA_ID=01912f00-0000-7000-8000-000000000001

# ---------- Observabilidad y respaldo ----------
SENTRY_DSN=
BACKUP_PASSPHRASE=
